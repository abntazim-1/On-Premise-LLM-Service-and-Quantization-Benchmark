FROM ubuntu:22.04

# Install build dependencies
RUN apt-get update && apt-get install -y build-essential cmake git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone and build llama.cpp server
RUN git clone https://github.com/ggerganov/llama.cpp.git && \
    cd llama.cpp && \
    cmake -B build && cmake --build build --config Release -j --target llama-server

EXPOSE 8000

ENTRYPOINT ["sh", "-c", "if [ -x /app/llama.cpp/build/bin/llama-server ]; then exec /app/llama.cpp/build/bin/llama-server \"$@\"; else exec /app/llama.cpp/build/llama-server \"$@\"; fi", "--"]
