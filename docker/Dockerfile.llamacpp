# Stage 1: Build stage
FROM ubuntu:22.04 AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone llama.cpp and check out a pinned, stable commit
RUN git clone https://github.com/ggerganov/llama.cpp.git && \
    cd llama.cpp && \
    git checkout a7312ae94f801fc9c6786dc56e38df57b964f697 && \
    cmake -B build -DLLAMA_CURL=ON -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build --config Release -j 4 --target llama-server

# Stage 2: Runtime stage
FROM ubuntu:22.04

# Install runtime libraries
RUN apt-get update && apt-get install -y \
    libcurl4 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the compiled server binary from the builder stage
COPY --from=builder /app/llama.cpp/build/bin/llama-server /app/llama-server

EXPOSE 8000

# Entrypoint for the llama.cpp server
ENTRYPOINT ["/app/llama-server"]

